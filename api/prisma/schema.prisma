// TestForge — Prisma schema
//
// Conventions (see CLAUDE.md / DECISIONS.md):
//   * All primary keys are UUIDs (String @id @default(uuid())).
//   * TestCase, TestPlan, VendorChange carry a separate monotonic `displayId`
//     (Int @default(autoincrement()) @unique) — rendered as TC-XXXX / TP-XXXX /
//     VC-XXXX in the app layer; permanent and never reused.
//   * Table names are snake_case via @@map; column names follow the model field.
//   * Market/region scoping is reserved for Phase 2 — `markets[]` / `marketTag`
//     fields are stored but not enforced in v1.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev; rhel-openssl-3.0.x for the Vercel serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled (PgBouncer) connection for app/serverless runtime.
  url       = env("DATABASE_URL")
  // Direct connection for migrations / `prisma db push` (no pooler).
  directUrl = env("DIRECT_URL")
}

// ---------- enums ----------

enum Role {
  SUPER_ADMIN
  TEST_MANAGER
  TEST_AUTHOR
  FIELD_OPERATOR
  OBSERVER
}

enum TestType {
  REGRESSION
  UAT
  MANUAL_FUNCTIONAL
  SMOKE
  EXPLORATORY
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum VendorCode {
  PBX
  LWS
  CPA
  HG
}

enum Environment {
  DEV
  TEST
  STAGING
  PROD
}

enum ExecutionStatus {
  NOT_STARTED
  IN_PROGRESS
  PASS
  FAIL
  BLOCKED
  SKIPPED
  // "Nice to have" — a non-blocking enhancement request raised during a run,
  // distinct from BLOCKED. See ENHANCEMENTS #8.
  ENHANCEMENT
}

// Workflow position of a run, independent of its pass/fail health. Drives the
// QC review queue and the path to approval. See ENHANCEMENTS #10/#11.
enum RunStage {
  IN_PROGRESS
  COMPLETED_BY_TESTER
  IN_QC_REVIEW
  READY_FOR_APPROVAL
  APPROVED
}

enum TestPlanType {
  REGRESSION
  UAT
  SMOKE
  FULL_CYCLE
}

enum TestPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum VendorChangeSeverity {
  BREAKING
  ENHANCEMENT
  PATCH
}

enum VendorChangeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AIAnalysisType {
  VENDOR_IMPACT
  COVERAGE_GAP
  TEST_GENERATION
  DUPLICATE_DETECTION
  STEP_CLARITY
}

// ---------- models ----------

model UserRole {
  id                 String   @id @default(uuid())
  // Stable internal subject id — the JWT subject and the value stored in every
  // ownerAccountId / assignedToAccountId field. App-managed users get a
  // generated UUID here. This is the seam a future Entra/AD `oid` will occupy
  // (see docs/AZURE-AD-MIGRATION.md). Renamed from atlassianAccountId, which was
  // misleading — there is no Atlassian account behind it.
  subjectId          String   @unique
  displayName        String
  // Login identifier for app-managed (email + password) authentication.
  email              String   @unique
  // scrypt hash ("scrypt$<salt>$<hash>"); null only for not-yet-provisioned rows.
  passwordHash       String?
  // Set when an admin issues a temp password — forces a change on next login.
  mustChangePassword Boolean  @default(false)
  role               Role
  // Reserved Phase 2 — not enforced in v1:
  markets            String[] @default([])
  projectKeys        String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("user_roles")
}

model TestFolder {
  id         String       @id @default(uuid())
  name       String
  parentId   String?
  parent     TestFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children   TestFolder[] @relation("FolderTree")
  vendorCode VendorCode?
  marketTag  String? // Reserved Phase 2
  projectKey String
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  testCases TestCase[]

  @@index([projectKey])
  @@index([parentId])
  @@map("test_folders")
}

model TestCase {
  id                       String         @id @default(uuid())
  // Human-facing monotonic id — rendered as TC-XXXX. Permanent, never reused.
  displayId                Int            @unique @default(autoincrement())
  title                    String
  objective                String?
  preconditions            String?
  testType                 TestType
  priority                 Priority
  status                   TestCaseStatus @default(DRAFT)
  vendors                  VendorCode[]   @default([])
  markets                  String[]       @default([]) // Reserved Phase 2
  environments             Environment[]  @default([])
  folderId                 String
  folder                   TestFolder     @relation(fields: [folderId], references: [id])
  ownerAccountId           String
  version                  Int            @default(1)
  aiGenerated              Boolean        @default(false)
  jiraStoryKeys            String[]       @default([])
  labels                   String[]       @default([])
  estimatedDurationMinutes Int?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  archivedAt               DateTime?

  steps            TestStep[]
  versions         TestCaseVersion[]
  cycleAssignments CycleAssignment[]
  executions       TestExecution[]

  @@index([folderId])
  @@index([status])
  @@index([ownerAccountId])
  @@map("test_cases")
}

model TestStep {
  id                String      @id @default(uuid())
  testCaseId        String
  testCase          TestCase    @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  order             Int
  action            String
  testData          String?
  expectedResult    String
  // When true, an execution of this step can't be marked until a screenshot
  // is attached — set by the case builder. See ENHANCEMENTS #6.
  screenshotRequired Boolean    @default(false)
  sharedStepId      String? // Optional reference into the shared-step library
  sharedStep        SharedStep? @relation(fields: [sharedStepId], references: [id])
  clarityScore      Int? // AI clarity score 1..10
  claritySuggestion String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  subSteps TestSubStep[]

  @@index([testCaseId])
  @@map("test_steps")
}

model TestSubStep {
  id             String   @id @default(uuid())
  testStepId     String
  testStep       TestStep @relation(fields: [testStepId], references: [id], onDelete: Cascade)
  order          Int
  action         String
  testData       String?
  expectedResult String

  @@index([testStepId])
  @@map("test_sub_steps")
}

model SharedStep {
  id                 String   @id @default(uuid())
  title              String
  action             String
  testData           String?
  expectedResult     String
  createdByAccountId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  usages TestStep[]

  @@map("shared_steps")
}

model TestCaseVersion {
  id                 String   @id @default(uuid())
  testCaseId         String
  testCase           TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  versionNumber      Int
  snapshot           Json // Full TestCase + steps payload at this version
  changedByAccountId String
  changeNotes        String?
  locked             Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@unique([testCaseId, versionNumber])
  @@index([testCaseId])
  @@map("test_case_versions")
}

model TestPlan {
  id                String         @id @default(uuid())
  // Human-facing monotonic id — rendered as TP-XXXX.
  displayId         Int            @unique @default(autoincrement())
  name              String
  description       String?
  planType          TestPlanType
  vendorCode        VendorCode?
  status            TestPlanStatus @default(DRAFT)
  targetEnvironment Environment
  jiraEpicKey       String?
  marketScope       String[]       @default([]) // Reserved Phase 2
  startDate         DateTime?
  endDate           DateTime?
  ownerAccountId    String
  projectKey        String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  cycles TestCycle[]

  @@index([projectKey])
  @@index([status])
  @@map("test_plans")
}

// A Package groups several runs (TestCycles) for a full end-to-end review —
// the third grouping level above Test Case → Run. See ENHANCEMENTS #3.
model Package {
  id             String          @id @default(uuid())
  // Human-facing monotonic id — rendered as PKG-XXXX.
  displayId      Int             @unique @default(autoincrement())
  name           String
  // Reuses TestType so a package can be labelled Regression / UAT / etc.
  packageType    TestType        @default(REGRESSION)
  // Rolled up from member runs at read time; persisted default only.
  status         ExecutionStatus @default(NOT_STARTED)
  ownerAccountId String
  projectKey     String
  // Package-level sign-off (identity-light, mirrors TestCycle). "Approved" = approvedAt != null.
  approverName   String?
  approvalNote   String?
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  cycles TestCycle[]

  @@index([projectKey])
  @@map("packages")
}

model TestCycle {
  id          String          @id @default(uuid())
  testPlanId  String
  testPlan    TestPlan        @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  // Optional parent package (a run can stand alone or belong to one package).
  packageId   String?
  package     Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  name        String
  environment Environment
  // QC workflow position (tester → manager review → ready for approval).
  stage       RunStage        @default(IN_PROGRESS)
  // Identity-light run assignee (free text / seeded name). Real per-user
  // enforcement is deferred to the Azure AD / SSO state — see ENHANCEMENTS #5.
  assigneeName String?
  // Identity-light approval sign-off (recorded when stage → APPROVED, or the
  // rejection note when sent back). A dedicated Approver role is future SSO
  // hardening. See ENHANCEMENTS #11.
  approverName String?
  approvalNote String?
  approvedAt   DateTime?
  // NOTE: ExecutionStatus reused per the brief; a cycle being SKIPPED/PASS is
  // semantically odd. Candidate for a dedicated CycleStatus enum in Sprint 2.
  status      ExecutionStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  assignments CycleAssignment[]
  executions  TestExecution[]

  @@index([testPlanId])
  @@index([packageId])
  @@map("test_cycles")
}

model CycleAssignment {
  id                  String    @id @default(uuid())
  testCycleId         String
  testCycle           TestCycle @relation(fields: [testCycleId], references: [id], onDelete: Cascade)
  testCaseId          String
  testCase            TestCase  @relation(fields: [testCaseId], references: [id])
  assignedToAccountId String
  assignedAt          DateTime  @default(now())

  @@index([testCycleId])
  @@index([assignedToAccountId])
  @@map("cycle_assignments")
}

model TestExecution {
  id                  String          @id @default(uuid())
  testCycleId         String
  testCycle           TestCycle       @relation(fields: [testCycleId], references: [id], onDelete: Cascade)
  testCaseId          String
  testCase            TestCase        @relation(fields: [testCaseId], references: [id])
  testCaseVersion     Int // Snapshot of TestCase.version at assignment time
  assignedToAccountId String
  executedByAccountId String?
  status              ExecutionStatus @default(NOT_STARTED)
  environment         Environment
  startedAt           DateTime?
  completedAt         DateTime?
  durationSeconds     Int?
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  stepResults ExecutionStepResult[]
  defects     Defect[]

  @@index([testCycleId])
  @@index([assignedToAccountId])
  @@index([status])
  @@map("test_executions")
}

model ExecutionStepResult {
  id             String          @id @default(uuid())
  executionId    String
  execution      TestExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testStepId     String
  stepOrder      Int
  status         ExecutionStatus
  actualResult   String?
  notes          String?
  attachmentUrls String[]        @default([]) // legacy/reserved (external URLs)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  attachments Attachment[]

  @@index([executionId])
  @@map("execution_step_results")
}

// Evidence (screenshots/files) attached to a step result during execution.
// Pilot: content is stored base64 in Postgres (no blob store yet); swap to an
// external blob store behind the store interface later. See ENHANCEMENTS #6.
model Attachment {
  id                  String              @id @default(uuid())
  stepResultId        String
  stepResult          ExecutionStepResult @relation(fields: [stepResultId], references: [id], onDelete: Cascade)
  filename            String
  contentType         String
  sizeBytes           Int
  dataBase64          String
  uploadedByAccountId String
  createdAt           DateTime            @default(now())

  @@index([stepResultId])
  @@map("attachments")
}

model Defect {
  id                  String        @id @default(uuid())
  executionId         String
  execution           TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  // Pilot defect fields (no Jira yet). Defaults keep `db push` safe.
  summary             String        @default("")
  description         String?
  severity            Priority      @default(MEDIUM)
  reportedByAccountId String        @default("")
  jiraIssueKey        String? // DS-XXXX once Jira creation succeeds
  createdByAI         Boolean       @default(false)
  duplicateOfKey      String? // Set if AI detected a duplicate at creation time
  jiraCreationPayload Json?
  createdAt           DateTime      @default(now())

  @@index([executionId])
  @@index([jiraIssueKey])
  @@map("defects")
}

model VendorChange {
  id                   String               @id @default(uuid())
  // Human-facing monotonic id — rendered as VC-XXXX.
  displayId            Int                  @unique @default(autoincrement())
  vendorCode           VendorCode
  versionTag           String
  summary              String
  affectedModules      String[]             @default([])
  severity             VendorChangeSeverity
  releaseDate          DateTime?
  status               VendorChangeStatus   @default(DRAFT)
  jiraIssueKeys        String[]             @default([])
  publishedAt          DateTime?
  publishedByAccountId String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  aiAnalyses AIAnalysis[]

  @@index([vendorCode])
  @@index([status])
  @@map("vendor_changes")
}

model AIAnalysis {
  id                  String         @id @default(uuid())
  analysisType        AIAnalysisType
  vendorChangeId      String?
  vendorChange        VendorChange?  @relation(fields: [vendorChangeId], references: [id])
  testCaseId          String? // For STEP_CLARITY
  executionId         String? // For DUPLICATE_DETECTION
  inputSummary        String
  outputJson          Json
  modelVersion        String // Resolved ANTHROPIC_MODEL at call time
  inputTokens         Int
  outputTokens        Int
  reviewedByAccountId String?
  reviewedAt          DateTime?
  createdAt           DateTime       @default(now())

  @@index([analysisType])
  @@index([vendorChangeId])
  @@map("ai_analyses")
}

model AuditLog {
  id             String   @id @default(uuid())
  actorAccountId String
  action         String // e.g. "TestCase.create", "TestExecution.update"
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorAccountId])
  @@index([createdAt])
  @@map("audit_logs")
}
