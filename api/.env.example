# TestForge API — environment variables
# Copy to .env.local for development. Required vars are validated on boot — the
# process exits with the missing-vars list if any are absent.

# ---------- runtime ----------
NODE_ENV=development
PORT=3001

# ---------- database ----------
# Local Postgres (docker run --name testforge-pg -e POSTGRES_PASSWORD=postgres ...).
# Pilot: Neon — DATABASE_URL is the pooled (-pooler) connection used at runtime;
# DIRECT_URL is the direct (non-pooled) connection Prisma uses for `db push` /
# migrations. Both are referenced by the datasource in prisma/schema.prisma.
# Note: the Prisma CLI reads .env, not .env.local — use `npm run db:push`, which
# loads .env.local via dotenv-cli.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/testforge?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/testforge?schema=public"

# ---------- app identity / auth ----------
# Authentication is app-managed email + password (DECISIONS.md ADR-008).
# Secret used to sign session JWTs. Set a long random value in every real
# environment; dev falls back to an insecure constant if unset.
TESTFORGE_INTERNAL_SECRET="generate-a-long-random-string"
# Bootstrap the first SUPER_ADMIN — seeded idempotently on boot so the user
# panel is reachable on a fresh DB. Sign in with these, then create everyone
# else from the Users & Roles panel (you'll be prompted to change this password
# on first login). Safe to remove once a real admin exists.
BOOTSTRAP_ADMIN_EMAIL="admin@everstory.com"
BOOTSTRAP_ADMIN_PASSWORD="change-me-on-first-login"

# ---------- Anthropic / AI ----------
# Default model per DECISIONS.md ADR-003. Override per environment.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Optional: route high-frequency, low-cost calls (duplicate detection, step
# clarity) to a Haiku-class model. If unset, ANTHROPIC_MODEL is used.
ANTHROPIC_MODEL_CHEAP="claude-haiku-4-5"
AI_MONTHLY_BUDGET_USD="150"

# ---------- Jira ----------
JIRA_BASE_URL="https://everstory.atlassian.net"
JIRA_SERVICE_ACCOUNT_EMAIL="testforge-bot@everstory.com"
JIRA_SERVICE_ACCOUNT_TOKEN="ATATT..."
JIRA_DEFAULT_PROJECT_KEY="DS"
JIRA_PROBLEM_ISSUE_TYPE="Problem"

# ---------- Forge ↔ API trust boundary ----------
# v1: shared secret between the Forge resolver and this API. The secret is
# attached in the resolver only; it never reaches the browser. Sprint 2 will
# replace this with verifying the Forge remote-invocation JWT.
TESTFORGE_INTERNAL_SECRET="generate-a-long-random-string"
# Forge app ARI, populated after the first `forge deploy`.
ALLOWED_FORGE_APP_ID="ari:cloud:ecosystem::app/..."

# ---------- Microsoft Teams ----------
TEAMS_WEBHOOK_IT_APPLICATIONS="https://everstory.webhook.office.com/webhookb2/..."
TEAMS_WEBHOOK_REPORTING="https://everstory.webhook.office.com/webhookb2/..."

# ---------- deep-link construction ----------
# Used to build "View in Jira" / "View in TestForge" links on Teams cards and
# inside Jira issue panels. Single canonical pair — no duplicates.
JIRA_PUBLIC_BASE_URL="https://everstory.atlassian.net"
FORGE_APP_ROUTE_BASE="https://everstory.atlassian.net/jira/apps"
