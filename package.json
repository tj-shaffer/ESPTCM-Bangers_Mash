{
  "name": "testforge",
  "version": "0.0.1",
  "private": true,
  "description": "TestForge — test case management for Everstory. Standalone Vite SPA + Express/Prisma API on Neon/Vercel (Azure is the future target). See STATUS.md.",
  "workspaces": [
    "forge-app",
    "api"
  ],
  "scripts": {
    "api:dev": "npm --workspace api run dev",
    "api:build": "npm --workspace api run build",
    "api:migrate": "npm --workspace api run db:migrate",
    "api:generate": "npm --workspace api run db:generate",
    "demo": "npm --prefix forge-app/static/frontend run demo"
  },
  "engines": {
    "node": ">=20"
  }
}
